# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# Database — Supabase Postgres (see DEPLOY.md step 1)
DATABASE_URL=""   # pooled connection, port 6543, add ?pgbouncer=true&connection_limit=1
DIRECT_URL=""     # session pooler, port 5432

# Image uploads — Vercel Blob (auto-set on Vercel; blank locally = /public/uploads)
BLOB_READ_WRITE_TOKEN=""

# Number-plate lookup — paid provider (blank = demo mode). See UK Vehicle Data.
UKVD_API_KEY=""
UKVD_PACKAGE="VehicleData"
# Optional free supplement (MOT months etc.)
DVLA_VES_API_KEY=""
MOT_CLIENT_ID=""
MOT_CLIENT_SECRET=""
MOT_API_KEY=""
MOT_TOKEN_URL=""
MOT_SCOPE="https://tapi.dvsa.gov.uk/.default"

# Admin auth — use strong values in production
ADMIN_PASSWORD="change-me"
AUTH_SECRET="generate-with: node -e \"console.log(require('crypto').randomBytes(32).toString('base64'))\""

# Public site / contact details
NEXT_PUBLIC_SITE_NAME="MIA Automotive"
NEXT_PUBLIC_PHONE="+44 7000 000000"
NEXT_PUBLIC_WHATSAPP="447000000000"
NEXT_PUBLIC_EMAIL="sales@miaautomotive.co.uk"
NEXT_PUBLIC_ADDRESS="South Shields, Tyne & Wear, UK"
NEXT_PUBLIC_INSTAGRAM="https://www.instagram.com/mia.automotive.ltd/"
